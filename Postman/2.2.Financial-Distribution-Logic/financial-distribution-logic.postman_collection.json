    {
      "name": "issue-voucer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 (Created)\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Transaction successful\", () => {\r",
              "    const res = pm.response.json();\r",
              "    pm.expect(res.status).to.eql(\"SUCCESS\");\r",
              "});\r",
              "\r",
              "pm.test(\"PIN is generated\", () => {\r",
              "    const res = pm.response.json();\r",
              "    pm.expect(res.pin).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"TraceId exists\", () => {\r",
              "    const res = pm.response.json();\r",
              "    pm.expect(res.traceId).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Response time < 2s\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
